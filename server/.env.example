# OpenMemory Server Environment Configuration
# Copy this file to .env and fill in the values.
#
# NEVER commit .env to version control!

# ============ PostgreSQL ============
POSTGRES_USER=openmemory
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=openmemory

# ============ Database URL (used by FastAPI app) ============
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://openmemory:CHANGE_ME_TO_A_STRONG_PASSWORD@postgres:5432/openmemory

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_TIMEOUT=30

# ============ Server ============
HOST=0.0.0.0
PORT=8080
DEBUG=false

# Environment: development | staging | production
ENVIRONMENT=development

# ============ CORS ============
# Comma-separated allowed origins
# Development: http://localhost:3000
# Production: https://app.openmemory.dev
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============ Rate Limiting (per hour) ============
RATE_LIMIT_REGISTER_PER_HOUR=10
RATE_LIMIT_STORE_PER_HOUR=1000
RATE_LIMIT_SEARCH_PER_HOUR=1000
RATE_LIMIT_SYNC_PER_HOUR=1000
RATE_LIMIT_ACCOUNT_PER_HOUR=10

# ============ API Version ============
# API_VERSION=0.3.1

# ============ Infrastructure ============
# Domain for Caddy TLS (use localhost for development)
DOMAIN=localhost

# ============ Relay / Subgraph (Phase 3 — Optional) ============
# PIMLICO_API_KEY=
# PIMLICO_BUNDLER_URL=https://api.pimlico.io/v2/84532/rpc
# DATA_EDGE_ADDRESS=
# ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# RELAY_RATE_LIMIT_OPS=100
# RELAY_RATE_LIMIT_WINDOW_SECONDS=3600
