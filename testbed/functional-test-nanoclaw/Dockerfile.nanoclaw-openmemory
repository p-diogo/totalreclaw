# Extends the NanoClaw agent container to add OpenMemory dependencies.
# The overlay files (modified index.ts, openmemory-mcp.ts, skills) are
# mounted via docker-compose volumes, NOT baked into this image.

FROM nanoclaw-agent:latest

# Add OpenMemory crypto dependencies
USER root
WORKDIR /app
RUN npm install @noble/hashes@^2.0.0 @scure/bip39@^2.0.0

# Create credentials directory owned by node user (for OpenMemory MCP server)
RUN mkdir -p /workspace/.openmemory && chown node:node /workspace/.openmemory

USER node
WORKDIR /workspace/group
