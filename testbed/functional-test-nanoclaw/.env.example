# Authentication — set at least ONE of the following two options:

# Option 1: OAuth token (for Claude subscription users)
# Run `claude setup-token` to get this value.
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token

# Option 2: Anthropic API key (for API key users)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# TotalReclaw recovery phrase — generate with: node generate-seed.mjs
# This 12-word phrase is the ONLY way to access your encrypted memories.
# If you lose it, your data is unrecoverable. Store it somewhere safe.
TOTALRECLAW_MASTER_PASSWORD="your twelve word recovery phrase goes here replace with actual generated words"

# Optional
POSTGRES_PASSWORD=test
