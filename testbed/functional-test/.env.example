# TotalReclaw Functional Test Environment
# Copy to .env and fill in your values:  cp .env.example .env

# =============================================================================
# REQUIRED
# =============================================================================

# LLM Provider — Z.AI API key (get one at https://zai.ai)
# Any OpenClaw-supported LLM provider works. If using a different provider,
# replace ZAI_API_KEY with the appropriate key and update OPENCLAW_LLM_PROVIDER
# and OPENCLAW_LLM_MODEL in docker-compose.functional-test.yml.
ZAI_API_KEY=your-zai-api-key-here

# TotalReclaw master mnemonic — a 12-word BIP-39 mnemonic used to derive all encryption keys.
# Generate one: npx tsx skill/plugin/generate-mnemonic.ts
# WARNING: If you lose this, your memories are unrecoverable (zero-knowledge).
# This mnemonic will later derive an Ethereum wallet for on-chain features (MVP roadmap).
TOTALRECLAW_MASTER_PASSWORD=your twelve word mnemonic goes here replace with actual generated words

# =============================================================================
# OPTIONAL (safe defaults provided)
# =============================================================================

# PostgreSQL password (defaults to "test" if unset — change for any shared env)
POSTGRES_PASSWORD=change-this-to-a-random-password
