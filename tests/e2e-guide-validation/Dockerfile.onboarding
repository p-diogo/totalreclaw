# Test: Fresh onboarding flow — plugin installed but NO recovery phrase
# Verifies the agent guides the user through mnemonic generation/restoration
FROM node:22-bookworm AS builder

RUN corepack enable
WORKDIR /openclaw
RUN git clone --depth 1 https://github.com/openclaw/openclaw.git .
RUN pnpm install --frozen-lockfile
RUN pnpm build

FROM node:22-bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /openclaw /app

# Install plugin from npm (same as npm-install test)
RUN mkdir -p /opt/totalreclaw-npm && \
    cd /opt/totalreclaw-npm && \
    npm pack @totalreclaw/totalreclaw 2>/dev/null && \
    tar xzf totalreclaw-totalreclaw-*.tgz && \
    mv package plugin && \
    rm -f *.tgz

RUN ls -la /opt/totalreclaw-npm/plugin/dist/index.js

# Create writable directories
RUN mkdir -p /home/node/.openclaw /home/node/.totalreclaw && \
    chown -R node:node /home/node/.openclaw /home/node/.totalreclaw /app /opt/totalreclaw-npm

COPY tests/e2e-guide-validation/entrypoint-onboarding.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER node
ENV NODE_ENV=production
ENV OPENCLAW_NO_TELEMETRY=1

WORKDIR /app
EXPOSE 18789

ENTRYPOINT ["/entrypoint.sh"]
