# Dockerfile.openclaw-mem0
#
# Builds OpenClaw from source (git clone) and installs the Mem0 memory plugin
# (@mem0/openclaw-mem0). Self-contained — no external build contexts needed.
#
# Usage:
#   docker build -f tests/e2e-import/Dockerfile.openclaw-mem0 -t openclaw-mem0:e2e .
#
# The docker-compose.yml handles the build context automatically.

# ---------------------------------------------------------------------------
# Stage 1: Build OpenClaw from source
# ---------------------------------------------------------------------------
FROM node:22-bookworm AS builder

RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

RUN corepack enable

WORKDIR /app

# Pin to v2026.3.8 — v2026.3.14 broke operator.write scope for token auth
RUN git clone --depth 1 --branch v2026.3.8 https://github.com/openclaw/openclaw.git .
RUN pnpm install --frozen-lockfile
RUN pnpm build

# ---------------------------------------------------------------------------
# Stage 2: Install Mem0 plugin into extensions directory
# ---------------------------------------------------------------------------
# The Mem0 plugin (@mem0/openclaw-mem0) is an npm package that needs to be
# installed into /app/extensions/openclaw-mem0/ alongside the bundled plugins.
#
# We install it directly (not via `openclaw plugins install`) because that
# command requires a running gateway. Instead, we npm-install the package
# into a temporary directory and copy the result into extensions/.

RUN mkdir -p /app/extensions/openclaw-mem0

# Create a minimal package.json, install the Mem0 plugin, then flatten
WORKDIR /app/extensions/openclaw-mem0
RUN echo '{"name":"openclaw-mem0-wrapper","private":true,"type":"module"}' > package.json && \
    npm install @mem0/openclaw-mem0@latest --save 2>&1 && \
    cp -r node_modules/@mem0/openclaw-mem0/* . && \
    rm -f package-lock.json

# ---------------------------------------------------------------------------
# Stage 3: Slim runtime image
# ---------------------------------------------------------------------------
FROM node:22-bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app /app

# Create writable directories
RUN mkdir -p /home/node/.openclaw && \
    chown -R node:node /home/node/.openclaw /app

USER node
ENV NODE_ENV=production
ENV OPENCLAW_NO_TELEMETRY=1

WORKDIR /app
EXPOSE 18789

CMD ["node", "dist/index.js", "gateway", "--allow-unconfigured"]
