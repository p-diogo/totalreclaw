# Mem0 Import E2E Test — Environment Variables
#
# Copy to .env and fill in real values: cp .env.example .env

# Z.AI API key — shared LLM for both instances
ZAI_API_KEY=your-zai-api-key

# Mem0 cloud API key (get from https://app.mem0.ai)
MEM0_API_KEY=m0-your-key-here

# TotalReclaw test mnemonic (any 12-word BIP-39 phrase)
TOTALRECLAW_MASTER_PASSWORD="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"
