# Dockerfile.openclaw-totalreclaw
#
# Builds OpenClaw from source and installs the TotalReclaw skill plugin.
# Adapted from tests/e2e-guide-validation/Dockerfile.openclaw.
#
# Build context must be the repo root (../..):
#   docker build -f tests/e2e-import/Dockerfile.openclaw-totalreclaw -t openclaw-totalreclaw:e2e ../..

# Stage 1: Build OpenClaw from source
FROM node:22-bookworm AS builder

RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

RUN corepack enable

WORKDIR /openclaw
# Pin to v2026.3.8 — v2026.3.14 broke operator.write scope for token auth
RUN git clone --depth 1 --branch v2026.3.8 https://github.com/openclaw/openclaw.git .
RUN pnpm install --frozen-lockfile
RUN pnpm build

# Stage 2: Runtime image
FROM node:22-bookworm-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl python3 ca-certificates && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy built OpenClaw
COPY --from=builder /openclaw /app

# Copy TotalReclaw skill plugin and install its deps
COPY skill/plugin/ /opt/totalreclaw/plugin/
COPY skill/SKILL.md /opt/totalreclaw/SKILL.md
WORKDIR /opt/totalreclaw/plugin
RUN npm install && npm install tslib

# Create writable directories
RUN mkdir -p /home/node/.openclaw /home/node/.totalreclaw && \
    chown -R node:node /home/node/.openclaw /home/node/.totalreclaw /app /opt/totalreclaw

# Copy entrypoint
COPY tests/e2e-import/entrypoint-totalreclaw.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER node
ENV NODE_ENV=production
ENV OPENCLAW_NO_TELEMETRY=1

WORKDIR /app
EXPOSE 18789

ENTRYPOINT ["/entrypoint.sh"]
