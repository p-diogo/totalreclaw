# E2E Integration Test Environment Variables
# These are test-only fake values used by docker-compose.yml.
# Real keys are in .env (not committed).

# Database
DATABASE_URL=postgresql+asyncpg://totalreclaw:test-password@postgres:5432/totalreclaw

# Server
HOST=0.0.0.0
PORT=8080
DEBUG=true
ENVIRONMENT=test
CORS_ORIGINS=*

# Free tier quotas (low for testing)
FREE_TIER_WRITES_PER_MONTH=5
FREE_TIER_READS_PER_MONTH=10

# Mock service endpoints
SUBGRAPH_ENDPOINT=http://mock-services:9090/subgraph
PIMLICO_BUNDLER_URL=http://mock-services:9090/bundler

# Contract addresses (Chiado testnet)
DATA_EDGE_ADDRESS=0x048879569E394af3fC6721d8d44DdcfcDD407543
ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# API keys — test-only fake values
PIMLICO_API_KEY=test_pimlico_key_for_e2e
STRIPE_SECRET_KEY=sk_test_fake_for_e2e
STRIPE_PRICE_ID=price_test_123
COINBASE_COMMERCE_API_KEY=fake_coinbase_key

# Webhook secrets (test values for signature verification)
STRIPE_WEBHOOK_SECRET=whsec_test_secret_for_e2e
COINBASE_COMMERCE_WEBHOOK_SECRET=coinbase_webhook_secret_for_e2e

# Rate limits (high for tests — all requests from same IP)
RATE_LIMIT_REGISTER_PER_HOUR=200
RATE_LIMIT_STORE_PER_HOUR=5000
RATE_LIMIT_SEARCH_PER_HOUR=5000
RATE_LIMIT_ACCOUNT_PER_HOUR=200
RATE_LIMIT_SYNC_PER_HOUR=5000
