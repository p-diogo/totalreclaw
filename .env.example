# TotalReclaw Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# LLM Configuration
# ===========================================
# NOTE: OpenClaw asks for API key during onboarding, not via env var
# When running `openclaw onboard`:
#   1. Choose Model/auth provider → Z.AI
#   2. Choose Coding-Plan-Global (international) or Coding-Plan-CN (China)
#   3. Paste your API key when prompted
# The key is stored in ~/.openclaw/openclaw.json

# For our Python scripts (fact extraction, ground truth generation, etc.)
# using z.ai API directly:
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/v1

# OpenRouter (for benchmark harness: synthetic data, ground truth, LLM judge)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter Models (all FREE tier)
# Trinity Large: 400B MoE, great for creative/generation tasks
# DeepSeek R1: o1-level reasoning, best for evaluation/judging
SYNTHETIC_DATA_MODEL=arcee-ai/trinity-large-preview:free
GROUND_TRUTH_MODEL=arcee-ai/trinity-large-preview:free
LLM_JUDGE_MODEL=deepseek/deepseek-r1-0528:free

# ===========================================
# Database Configuration
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=totalreclaw
DB_USER=totalreclaw
DB_PASSWORD=dev  # Change for production!

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===========================================
# TotalReclaw Server (PoC)
# ===========================================
TOTALRECLAW_SERVER_URL=http://localhost:8080
TOTALRECLAW_ENV=development

# ===========================================
# OpenClaw Configuration (Docker instances)
# ===========================================
# ⚠️ OpenClaw runs in Docker ONLY - never on host
# ⚠️ Never expose to internet - localhost only
OPENCLAW_QMD_PORT=8081
OPENCLAW_MEM0_PORT=8082

# Mem0 API Key (for Mem0 plugin testing)
MEM0_API_KEY=your_mem0_api_key_here

# ===========================================
# Python Configuration
# ===========================================
PYTHONPATH=./src
VENV_PATH=./.venv
