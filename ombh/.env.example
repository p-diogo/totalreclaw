# 4-Way Memory System Benchmark — Environment Variables
#
# SECURITY:
#   - This file contains sensitive API keys
#   - NEVER commit this file to version control
#   - Copy to .env and fill in your values:  cp .env.example .env

# =============================================================================
# REQUIRED (all instances)
# =============================================================================

# Z.AI API key — shared across all 4 OpenClaw instances for fair LLM comparison
# Get one at https://zai.ai
ZAI_API_KEY=your-zai-api-key-here

# =============================================================================
# REQUIRED (TotalReclaw instance only)
# =============================================================================

# BIP-39 mnemonic for TotalReclaw E2EE key derivation
# Generate one: cd skill/plugin && npx tsx generate-mnemonic.ts
# WARNING: If you lose this, your memories are unrecoverable (zero-knowledge).
TOTALRECLAW_MASTER_PASSWORD=your twelve word mnemonic goes here replace with actual generated words

# PostgreSQL password for TotalReclaw's server database
POSTGRES_PASSWORD=change-this-to-a-random-password

# =============================================================================
# REQUIRED (LanceDB instance only)
# =============================================================================

# OpenAI API key — used by LanceDB plugin for embeddings (text-embedding-3-small)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# REQUIRED (Mem0 instance)
# =============================================================================

# Mem0 cloud API key — used by the Mem0 memory plugin for cloud-based memory
# Get one at https://app.mem0.ai (free tier available)
# The Mem0 plugin (@mem0/openclaw-mem0) is installed via a custom Dockerfile
# during the Docker build — no manual plugin installation needed.
MEM0_API_KEY=your-mem0-api-key-here

# =============================================================================
# BENCHMARK CONFIGURATION (optional overrides)
# =============================================================================

# Gateway token — shared across all instances for API access
# Default: benchmark-token-2026 (set in each config.json5)
# BENCHMARK_GATEWAY_TOKEN=benchmark-token-2026
