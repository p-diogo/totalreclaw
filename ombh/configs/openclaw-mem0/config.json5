{
  "meta": {
    "lastTouchedVersion": "2026.2.22",
    "lastTouchedAt": "2026-02-26T00:00:00.000Z"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "zai/glm-4.5-air"
      },
      "models": {
        "zai/glm-4.5-air": {}
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "benchmark-token-2026"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  // Mem0 cloud memory plugin (@mem0/openclaw-mem0)
  // Requires MEM0_API_KEY environment variable (get from https://app.mem0.ai)
  // Auto-recall and auto-capture are enabled by default.
  "plugins": {
    "slots": {
      "memory": "openclaw-mem0"
    },
    "entries": {
      "openclaw-mem0": {
        "enabled": true,
        "config": {
          "apiKey": "${MEM0_API_KEY}",
          "userId": "benchmark-user"
        }
      },
      "memory-core": {
        "enabled": false
      },
      "memory-lancedb": {
        "enabled": false
      }
    }
  }
}
