# Dockerfile.openclaw-totalreclaw-v1
#
# TotalReclaw v1 (facts-only, no embeddings/LSH).
# Same plugin code as v2, but with a STUB @huggingface/transformers module
# that prevents the ONNX model from loading. The plugin loads successfully
# but generateEmbedding() always throws, triggering BM25-only fallback.

FROM node:22-bookworm@sha256:cd7bcd2e7a1e6f72052feb023c7f6b722205d3fcab7bbcbd2d1bfdab10b1e935 AS openclaw-base

RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"
RUN corepack enable

WORKDIR /app
RUN chown node:node /app

COPY --from=openclaw-src --chown=node:node package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY --from=openclaw-src --chown=node:node ui/package.json ./ui/package.json
COPY --from=openclaw-src --chown=node:node patches ./patches
COPY --from=openclaw-src --chown=node:node scripts ./scripts

USER node
RUN pnpm install --frozen-lockfile

COPY --from=openclaw-src --chown=node:node . .
RUN pnpm build
ENV OPENCLAW_PREFER_PNPM=1
RUN pnpm ui:build

# Install TotalReclaw plugin with all deps
USER root
RUN mkdir -p /app/extensions/totalreclaw && chown node:node /app/extensions/totalreclaw
RUN mkdir -p /app/skills/totalreclaw && chown node:node /app/skills/totalreclaw
USER node

WORKDIR /app/extensions/totalreclaw
COPY --from=totalreclaw-plugin --chown=node:node package.json package-lock.json openclaw.plugin.json ./
COPY --from=totalreclaw-plugin --chown=node:node *.ts ./
RUN npm install 2>&1

# Replace @huggingface/transformers with a stub that always fails at runtime.
# The plugin catches embedding errors and falls back to BM25-only (v1 behavior).
RUN rm -rf node_modules/@huggingface/transformers && \
    mkdir -p node_modules/@huggingface/transformers && \
    echo 'export async function pipeline() { throw new Error("Embeddings disabled (v1 mode)"); }' > node_modules/@huggingface/transformers/index.js && \
    echo '{"name":"@huggingface/transformers","version":"0.0.0-stub","main":"index.js","type":"module"}' > node_modules/@huggingface/transformers/package.json

COPY --from=totalreclaw-skill --chown=node:node SKILL.md /app/skills/totalreclaw/SKILL.md

WORKDIR /app
ENV NODE_ENV=production
USER node
CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
