# Dockerfile.openclaw-lancedb
#
# Extends the OpenClaw base image to install the `openai` npm package
# required by the bundled memory-lancedb plugin for embeddings.

FROM node:22-bookworm@sha256:cd7bcd2e7a1e6f72052feb023c7f6b722205d3fcab7bbcbd2d1bfdab10b1e935 AS openclaw-base

RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:${PATH}"

RUN corepack enable

WORKDIR /app
RUN chown node:node /app

COPY --from=openclaw-src --chown=node:node package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY --from=openclaw-src --chown=node:node ui/package.json ./ui/package.json
COPY --from=openclaw-src --chown=node:node patches ./patches
COPY --from=openclaw-src --chown=node:node scripts ./scripts

USER node
RUN pnpm install --frozen-lockfile

COPY --from=openclaw-src --chown=node:node . .
RUN pnpm build
ENV OPENCLAW_PREFER_PNPM=1
RUN pnpm ui:build

# ---------------------------------------------------------------------------
# Install openai SDK into the bundled memory-lancedb extension
# The plugin uses workspace:* deps, so npm can't resolve from its package.json.
# Instead, install openai into a temp dir and symlink into the extension's node_modules.
# ---------------------------------------------------------------------------
USER root
RUN mkdir -p /tmp/openai-install && chown node:node /tmp/openai-install
USER node

WORKDIR /tmp/openai-install
RUN echo '{"private":true}' > package.json && npm install openai 2>&1
RUN mkdir -p /app/extensions/memory-lancedb/node_modules && \
    cp -r /tmp/openai-install/node_modules/* /app/extensions/memory-lancedb/node_modules/

WORKDIR /app

ENV NODE_ENV=production
USER node

CMD ["node", "openclaw.mjs", "gateway", "--allow-unconfigured"]
